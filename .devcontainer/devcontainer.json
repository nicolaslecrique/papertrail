{
  "name": "papertrail",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspace",
  "remoteUser": "vscode",

  "features": {
    "ghcr.io/devcontainers/features/node:1": {},
    "ghcr.io/anthropics/devcontainer-features/claude-code:1.0": {}
  },

  // Bind-mount the host's real Claude Code config/credentials so every
  // container (and every clone opened via scripts/agent.sh) is already
  // logged in on open - no separate in-container login step.
  // Trade-off: the host and every container share the exact same live
  // session/credentials/history files - fine for one person's own machine,
  // but means concurrent writers (host + containers) can race on them, and
  // this only works when the devcontainer runs on the same host as ~/.claude.
  // ~/.claude.json is a sibling *file* (not inside ~/.claude/) that holds
  // most of the persistent login/onboarding state, so it needs its own mount.
  "mounts": [
    "source=${localEnv:HOME}/.claude,target=/home/vscode/.claude,type=bind",
    "source=${localEnv:HOME}/.claude.json,target=/home/vscode/.claude.json,type=bind"
  ],

  // A brand-new clone/scaffold has no pyproject.toml yet on first boot -
  // don't fail on that, and don't mask a genuine `uv sync` failure either.
  "postCreateCommand": "bash -c 'if [ -f pyproject.toml ]; then uv sync; else echo \"No pyproject.toml yet - skipping uv sync\"; fi'",

  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python", "charliermarsh.ruff"]
    }
  }
}
