{
  "name": "papertrail",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspace",
  "remoteUser": "vscode",

  // The backend API (uvicorn) and the frontend dev server (TanStack Start / Vite,
  // which proxies /api to the backend). VS Code auto-forwards both to the host.
  "forwardPorts": [8000, 3000],
  "portsAttributes": {
    "8000": { "label": "backend (FastAPI)" },
    "3000": { "label": "frontend (TanStack Start)" }
  },

  // Node itself comes solely from the Dockerfile's pinned COPY (including the
  // npm/npx symlinks it recreates) - not from a "node" feature. The
  // claude-code feature below only installs its own Node if `node` or `npm`
  // is missing from PATH, so it detects and reuses this pinned install
  // instead of pulling in a second, unpinned one via nvm.
  "features": {
    "ghcr.io/anthropics/devcontainer-features/claude-code:1.0": {}
  },

  // Bind-mount the host's real Claude Code config/credentials so every
  // container (and every clone opened via scripts/agent.sh) is already
  // logged in on open - no separate in-container login step.
  // Trade-off: the host and every container share the exact same live
  // session/credentials/history files - fine for one person's own machine,
  // but means concurrent writers (host + containers) can race on them, and
  // this only works when the devcontainer runs on the same host as ~/.claude.
  // ~/.claude.json is a sibling *file* (not inside ~/.claude/) that holds
  // most of the persistent login/onboarding state, so it needs its own mount.
  "mounts": [
    "source=${localEnv:HOME}/.claude,target=/home/vscode/.claude,type=bind",
    "source=${localEnv:HOME}/.claude.json,target=/home/vscode/.claude.json,type=bind"
  ],

  // Install backend + frontend + e2e deps, then bring the app database (the
  // `papertrail` database used by `uv run uvicorn`) up to the latest schema so
  // it's ready to use on open - `alembic upgrade head` is idempotent (a no-op
  // once already at head).
  "postCreateCommand": "just install && just migrate",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff",
        "meta.pyrefly",
        "ms-playwright.playwright",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "ms-ossdata.vscode-pgsql"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/workspace/.venv/bin/python",
        "python.testing.pytestEnabled": true,
        "python.testing.unittestEnabled": false,
        "ruff.importStrategy": "fromEnvironment",
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff",
          "editor.formatOnSave": true,
          "editor.codeActionsOnSave": { "source.fixAll.ruff": "explicit" }
        },

        // Connection profiles for the PostgreSQL extension, pointing at the `db`
        // service in docker-compose.yml (reachable by service name from inside
        // this container; there is no host port mapping on purpose).
        //
        // `papertrail` is the role created by POSTGRES_USER, which Postgres makes
        // a superuser - so these are admin connections. The password is the
        // dev-only credential already committed in docker-compose.yml.
        //
        // These settings are materialized into the container's Machine settings
        // (~/.vscode-server/data/Machine/settings.json) on container create. The
        // extension reads `password` from there once, moves it into its credential
        // store, and blanks it in that file - which is why the password must live
        // here and not in a committed .vscode/settings.json: that file would be
        // rewritten on every load and show up as a dirty working tree. Machine
        // settings are disposable and re-seeded from this file on every rebuild.
        // `savePassword` is what makes the extension keep it instead of prompting.
        "pgsql.serverGroups": [
          {
            "id": "papertrail-devcontainer",
            "name": "papertrail (devcontainer)",
            "description": "Postgres running in the devcontainer's `db` service"
          }
        ],
        "pgsql.connections": [
          {
            "id": "papertrail-dev",
            "groupId": "papertrail-devcontainer",
            "profileName": "papertrail (admin)",
            "server": "db",
            "port": "5432",
            "database": "papertrail",
            "user": "papertrail",
            "password": "papertrail",
            "savePassword": true,
            "authenticationType": "SqlLogin",
            "sslmode": "disable",
            "applicationName": "vscode-pgsql",
            "connectTimeout": 15
          },
          {
            // Created on demand by tests/conftest.py - absent until pytest has run.
            "id": "papertrail-test",
            "groupId": "papertrail-devcontainer",
            "profileName": "papertrail_test (admin)",
            "server": "db",
            "port": "5432",
            "database": "papertrail_test",
            "user": "papertrail",
            "password": "papertrail",
            "savePassword": true,
            "authenticationType": "SqlLogin",
            "sslmode": "disable",
            "applicationName": "vscode-pgsql",
            "connectTimeout": 15
          }
        ]
      }
    }
  }
}
