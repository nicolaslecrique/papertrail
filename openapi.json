            "description": "Missing token or inactive user."
          }
        },
        "security": [
          {
            "APIKeyCookie": []
          }
        ],
        "summary": "Users:Current User",
        "tags": [
          "users"
        ]
      },
      "patch": {
        "operationId": "users:patch_current_user",
