{
  "name": "papertrail-frontend",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.10.0",
  "scripts": {
    "build": "pnpm run build:css && pnpm run build:js && pnpm run build:hash",
    "build:css": "tailwindcss -i app/web/static/app.tailwind.css -o app/web/static/app.css --minify",
    "build:js": "cp node_modules/htmx.org/dist/htmx.min.js app/web/static/htmx.min.js",
    "build:hash": "bash scripts/assets-fingerprint.sh > app/web/static/assets.sha256"
  },
  "dependencies": {
    "htmx.org": "^2.0.10"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.2",
    "daisyui": "^5.6.14",
    "tailwindcss": "^4.3.2"
  }
}
